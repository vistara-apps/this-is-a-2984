# BrandSync AI Video - Environment Variables
# Copy this file to .env and fill in your actual values

# API Base URL
VITE_API_BASE_URL=http://localhost:3001/api

# AI Service API Keys
VITE_RUNWAY_API_KEY=your_runway_api_key_here
VITE_PICTORY_API_KEY=your_pictory_api_key_here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Authentication
VITE_JWT_SECRET=your_jwt_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# File Upload Configuration
VITE_MAX_FILE_SIZE=100MB
VITE_ALLOWED_FILE_TYPES=mp4,mov,avi,jpg,jpeg,png,gif,pdf,txt,docx

# Feature Flags
VITE_ENABLE_DEMO_MODE=true
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_STRIPE_PAYMENTS=true

# Development Settings
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
